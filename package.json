{
  "name": "executecmdupdater",
  "version": "1.2.5",
  "description": "一个用于更新mc存档中/execute指令的工具",
  "main": "main.js",
  "dependencies": {
    "brigadier-ts": "^1.4.1",
    "emldb": "^1.0.1",
    "parsenbt-js": "^3.1.0"
  },
  "author": "HTMonkeyG",
  "license": "MIT",
  "bin": "./main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "pkg . --out-path=dist/"
  },
  "pkg": {
    "scripts": "build/**/*.js",
    "targets": [
      "node18"
    ],
    "assets": [
      "node_modules/leveldb-zlib",
      "node_modules/parsenbt-js"
    ],
    "outputPath": "dist"
  }
}
